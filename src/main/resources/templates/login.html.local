<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - Plateforme d'Annotation NLP</title>
    <link rel="stylesheet" th:href="@{/css/style.css}">
</head>
<body style="justify-content: center; align-items: center;">

    <div class="login-card">
        <div class="logo" style="justify-content: center; margin-bottom: 10px;">
            <span>🧠</span> NLP Annotation
        </div>
        <h1 class="login-title">Bienvenue</h1>
        <p class="login-subtitle">Connectez-vous pour accéder à votre espace de travail</p>

        <!-- Messages d'alerte sécurisés -->
        <div th:if="${param.error}" class="login-alert alert-error">
            🔑 Identifiants incorrects ou compte inactif.
        </div>
        <div th:if="${param.logout}" class="login-alert alert-success">
            🚪 Vous avez été déconnecté avec succès.
        </div>

        <form th:action="@{/login}" method="POST">
            <div class="form-group">
                <label for="username" class="form-label">Nom d'utilisateur (Login)</label>
                <input type="text" id="username" name="username" class="form-control" placeholder="Entrez votre identifiant" required autofocus>
            </div>
            
            <div class="form-group" style="margin-bottom: 30px;">
                <label for="password" class="form-label">Mot de passe</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Entrez votre mot de passe" required>
            </div>

            <button type="submit" class="btn" style="width: 100%; padding: 14px;">
                Se connecter
            </button>
        </form>
        
        <div style="margin-top: 25px; text-align: center; font-size: 13px; color: var(--text-secondary);">
            Besoin d'aide ? Contactez l'administrateur système.
        </div>
    </div>

</body>
</html>
